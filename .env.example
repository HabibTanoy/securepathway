# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://securepathway:password@localhost:5432/securepathway

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string-min-64-chars
JWT_REFRESH_SECRET=change-this-to-another-long-random-string-min-64-chars

# ── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Leave blank in development — emails log to console only
# Works with Postmark, Mailgun, AWS SES, Gmail SMTP, or any provider
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=SecurePathway <noreply@securepathway.io>

# ── xAPI / LRS (optional) ────────────────────────────────────────────────────
# Leave blank to store statements locally only (xapi_statements table)
# Tested with SCORM Cloud LRS and Learning Locker
LRS_ENDPOINT=
LRS_KEY=
LRS_SECRET=
